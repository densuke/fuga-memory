# fuga-memory 環境変数テンプレート
#
# 設定ファイル (config.toml) を使う場合は通常不要です。
# 環境変数は設定ファイルより優先されます。
#
# このファイルをコピーして .env として使用するか、シェルで export してください。
# Docker / CI 環境など、ファイル配置が難しい場面で使用します。

# SQLite データベースファイルのパス
# FUGA_MEMORY_DB_PATH=~/.local/share/fuga-memory/memories.db

# 埋め込みモデル名 (HuggingFace Hub のモデル ID)
# FUGA_MEMORY_MODEL_NAME=cl-nagoya/ruri-v3-310m

# 推論・DB 操作に使用するスレッド数 (整数)
# FUGA_MEMORY_THREAD_WORKERS=2

# RRF の k パラメータ (整数)
# FUGA_MEMORY_RRF_K=60

# 時間減衰の半減期（日数、整数）
# FUGA_MEMORY_DECAY_HALFLIFE_DAYS=30

# search_memory のデフォルト返却件数 (整数)
# FUGA_MEMORY_DEFAULT_TOP_K=5

# デーモンの待ち受けポート番号 (整数)
# FUGA_MEMORY_DAEMON_PORT=18520

# デーモンのアイドル自動終了までの秒数 (整数)
# FUGA_MEMORY_DAEMON_IDLE_TIMEOUT=600

# ONNX モデルキャッシュのベースディレクトリ (パス文字列)
# FUGA_MEMORY_ONNX_CACHE_DIR=~/.local/share/fuga-memory/onnx_cache

# デバッグモード (1/true/yes で有効、ライブラリ警告・ログを抑制しない)
# FUGA_MEMORY_DEBUG=false
